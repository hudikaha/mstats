# Replace __PUBLIC_BASIC_AUTH__ with the Base64 encoding of account:password.
# Keep the rendered configuration private on the server.

location ~ ^/elastic/(?<es_index>mstats|kcor|vdeath|indiv|indivdth)/(?<es_api>_search|_count|_mapping|_field_caps)$ {
  limit_except GET POST OPTIONS { deny all; }

  if ($request_method = OPTIONS) {
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Content-Type" always;
    add_header Access-Control-Max-Age 86400 always;
    return 204;
  }

  client_max_body_size 1m;
  proxy_connect_timeout 5s;
  proxy_read_timeout 30s;
  proxy_pass http://127.0.0.1:9200/$es_index/$es_api$is_args$args;
  proxy_set_header Authorization "Basic __PUBLIC_BASIC_AUTH__";
  proxy_set_header Content-Type $content_type;
  proxy_hide_header WWW-Authenticate;

  add_header Access-Control-Allow-Origin "*" always;
  add_header Cache-Control "no-store" always;
}

location ~ ^/elastic/(?<es_index>mstats|kcor|vdeath|indiv|indivdth)/_doc/(?<es_id>[^/]+)$ {
  limit_except GET OPTIONS { deny all; }

  if ($request_method = OPTIONS) {
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Content-Type" always;
    add_header Access-Control-Max-Age 86400 always;
    return 204;
  }

  proxy_connect_timeout 5s;
  proxy_read_timeout 30s;
  proxy_pass http://127.0.0.1:9200/$es_index/_doc/$es_id;
  proxy_set_header Authorization "Basic __PUBLIC_BASIC_AUTH__";
  proxy_hide_header WWW-Authenticate;

  add_header Access-Control-Allow-Origin "*" always;
  add_header Cache-Control "no-store" always;
}

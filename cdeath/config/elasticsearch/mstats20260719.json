{
  "settings": {
    "number_of_shards": 1,
    "max_result_window": 1000000,
    "index.mapping.coerce": false
  },
  "mappings": {
    "dynamic": true,
    "dynamic_templates": [
      {
        "age_values": {
          "match": "age_*",
          "mapping": {
            "type": "scaled_float",
            "scaling_factor": 100
          }
        }
      }
    ],
    "properties": {
      "id":          { "type": "keyword" },
      "loc_code":    { "type": "keyword" },
      "location":    { "type": "keyword" },
      "yearmonth":   { "type": "keyword" },
      "yearweek":    { "type": "keyword" },
      "category":    { "type": "keyword" },
      "rate":        { "type": "keyword" },
      "death_code":  { "type": "keyword" },
      "death_cause": { "type": "keyword" },
      "algo":        { "type": "keyword" },
      "type":        { "type": "keyword" },
      "date":        { "type": "date", "format": "yyyy-MM-dd" },
      "@timestamp":  { "type": "date" },
      "year":        { "type": "integer" },
      "month":       { "type": "integer" },
      "week":        { "type": "integer" },
      "sex":         { "type": "keyword" }
    }
  }
}
